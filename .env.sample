NODE_ENV=dev

APP_URL=http://localhost:3000

# =====================
# DATABASE
# =====================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>
DB_NAME=farmera
DB_SYNC=false
DB_LOGGING=false

# =====================
# STORAGE
# =====================
# Chọn một: LOCAL | R2
STORAGE_TYPE=LOCAL
ADDRESS_TYPE=OLD

# =====================
# AUTH (JWT)
# =====================
JWT_ACCESS_TOKEN_SECRET=<access-token-secret>
JWT_ACCESS_TOKEN_EXPIRATION=1d
JWT_REFRESH_TOKEN_SECRET=<refresh-token-secret>
JWT_REFRESH_TOKEN_EXPIRATION=30d

# =====================
# ADDRESS API
# =====================
ADDRESS_API_ENDPOINT=https://provinces.open-api.vn/api/v2
OLD_ADDRESS_API_ENDPOINT=https://provinces.open-api.vn/api/v1

# =====================
# TWILIO & SENDGRID
# =====================
TWILIO_SENDGRID_API_KEY=<sendgrid-api-key>
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_VERIFY_SERVICE_SID=<twilio-verify-service-sid>
FROM_EMAIL=<from-email>

# =====================
# CLOUDFLARE R2 (nếu STORAGE_TYPE=R2)
# =====================
R2_TOKEN_VALUE=<r2-token-value>
R2_ACCOUNT_ID=<r2-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_ACCESS_KEY_SECRET=<r2-access-key-secret>
R2_BUCKET_NAME=farmera
R2_PRIVATE_BUCKET_NAME=farmera-private

FILE_ENCRYPTION_KEY=<64-char-hex-key>

# =====================
# FPT AI
# =====================
FPT_API_KEY=<fpt-api-key>
FPT_IDR_URL=https://api.fpt.ai/vision/idr/vnm
FPT_LIVENESS_URL=https://api.fpt.ai/dmp/liveness/v3

# =====================
# BLOCKCHAIN
# =====================
# --- Local (Anvil) ---
BLOCKCHAIN_PROVIDER=anvil
RPC_URL=http://127.0.0.1:8545
WALLET_PRIVATE_KEY=<wallet-private-key>
PROCESS_TRACKING_CONTRACT_ADDRESS=<contract-address>
TRUST_COMPUTATION_CONTRACT_ADDRESS=<contract-address>
AUDIT_REGISTRY_CONTRACT_ADDRESS=<contract-address>

# --- Testnet (Sepolia) ---
# BLOCKCHAIN_PROVIDER=sepolia
# RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<alchemy-api-key>
# WALLET_PRIVATE_KEY=<wallet-private-key>
# PROCESS_TRACKING_CONTRACT_ADDRESS=<contract-address>

# =====================
# PAYOS (thanh toán)
# =====================
PAYOS_CREATE_ORDER_URL=https://api-merchant.payos.vn/v2/payment-requests
PAYOS_API_KEY=<payos-api-key>
PAYOS_CHECKSUM=<payos-checksum-key>
PAYOS_CLIENT_ID=<payos-client-id>
WEB_HOOK_RETURN_URL=https://<your-domain>/payment/return
WEB_HOOK_CANCEL_URL=https://<your-domain>/payment/cancel

# =====================
# GHN (vận chuyển)
# =====================
GHN_TOKEN=<ghn-token>
GHN_SHOP_ID=<ghn-shop-id>
GHN_GET_PROVINCE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/master-data/province
GHN_GET_DISTRICT_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/master-data/district
GHN_GET_WARD_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/master-data/ward
GHN_CALCULATE_DELIVERY_FEE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2/shipping-order/fee
GHN_CREATE_ORDER_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2/shipping-order/create
GHN_CANCEL_ORDER_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2/switch-status/cancel
GHN_GET_ORDER_DETAIL_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2/shipping-order/detail

# =====================
# GOOGLE CLOUD (Vision API)
# =====================
GOOGLE_APPLICATION_CREDENTIALS=<đường-dẫn-tới-file-credentials.json>
